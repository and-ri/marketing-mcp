# =====================================================
# Google Ads API
# https://developers.google.com/google-ads/api/docs/first-call/overview
# =====================================================
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# Required only for manager (MCC) accounts:
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# =====================================================
# Google Analytics 4 (GA4 Data API)
# Same OAuth2 client can be reused if scopes include analytics.readonly
# https://developers.google.com/analytics/devguides/reporting/data/v1
# =====================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# =====================================================
# Meta (Facebook / Instagram) Ads
# https://developers.facebook.com/docs/marketing-api/overview
# =====================================================
META_APP_ID=
META_APP_SECRET=
# Long-lived user or system user access token with ads_read permission
META_ACCESS_TOKEN=

# =====================================================
# TikTok Ads
# https://business-api.tiktok.com/portal/en/start
# =====================================================
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
# Access token obtained via OAuth2 flow (auth_start_tiktok / auth_finish_tiktok)
TIKTOK_ACCESS_TOKEN=
